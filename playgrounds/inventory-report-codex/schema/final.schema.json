{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed"]
    },
    "artifact": {
      "type": "string",
      "enum": ["workspace/result.json"]
    },
    "verification": {
      "type": "string",
      "enum": ["passed"]
    }
  },
  "required": [
    "status",
    "artifact",
    "verification"
  ],
  "additionalProperties": false
}
