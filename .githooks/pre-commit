#!/bin/sh
# Generated by `coherence init`. See AGENTS.md for the contract.
set -e

if [ "${COHERENCE_OFF:-0}" = "1" ]; then
  exit 0
fi

# Prefer a coherence binary on PATH; fall back to the common Go install dir.
if ! command -v coherence >/dev/null 2>&1; then
  if [ -x "$HOME/go/bin/coherence" ]; then
    PATH="$HOME/go/bin:$PATH"
    export PATH
  fi
fi

if ! command -v coherence >/dev/null 2>&1; then
  echo "coherence: binary not found on PATH; skipping pre-commit checks" >&2
  echo "          (install with: go install github.com/fireharp/coherence/cmd/coherence@latest)" >&2
  exit 0
fi

exec coherence scan --staged
